{
  "name": "@pagefind/md-indexer",
  "version": "0.1.0",
  "description": "Index markdown files directly via the Pagefind Node API",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "md-indexer": "./dist/esm/cli.js"
  },
  "scripts": {
    "build": "node build.js && tsc -p tsconfig.d.json",
    "typecheck": "tsc --noEmit",
    "test": "ava"
  },
  "files": [
    "./dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "dependencies": {
    "fast-glob": "^3.3.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "mdast-util-to-string": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0"
  },
  "peerDependencies": {
    "pagefind": "*",
    "remark-mdx": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "remark-mdx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "ava": "^6.4.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.5",
    "typescript": "^5.0.0"
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "nodeArguments": [
      "--import=tsx/esm"
    ]
  },
  "author": "Pagefind",
  "license": "MIT"
}
