{
  "include": [
    "./src/**/*.ts"
  ],
  "exclude": [
    "./node_modules",
    "./dist"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist/types",
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "es2022",
    "lib": [
      "ES2022"
    ],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "declaration": true,
    "emitDeclarationOnly": true
  }
}
